{
  "name": "tenrai.js",
  "version": "1.0.0",
  "description": "A simple and typed client to fetch anime, manga, characters and user data from tenrai.org",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "packageManager": "pnpm@11.8.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.8.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:generate": "typedoc",
    "docs:dev": "pnpm run docs:generate && vitepress dev docs",
    "docs:build": "pnpm run docs:generate && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "myanimelist",
    "anime",
    "manga",
    "tenrai",
    "api",
    "wrapper",
    "typescript",
    "Jikan"
  ],
  "author": "gonzyui",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gonzyui/tenrai.js"
  },
  "bugs": {
    "url": "https://github.com/gonzyui/tenrai.js/issues"
  },
  "homepage": "https://github.com/gonzyui/tenrai.js#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.10"
  },
  "onlyBuiltDependencies": [
    "esbuild"
  ]
}